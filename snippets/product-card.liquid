{% assign product_image = product.featured_media.preview_image | default: product.featured_image %}
<article class="product-card">
  <a class="product-card__media" href="{{ product.url }}">
    {% if product_image %}
      {{ product_image | image_url: width: 520 | image_tag: loading: 'lazy', alt: product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
  </a>
  {% if product.available %}
    {% form 'product', product, class: 'product-card__cart-form' %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button class="product-card__cart-button" type="submit" aria-label="Add {{ product.title }} to cart">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6.2 7h14.1l-1.7 8.2H8L6.2 7Z"></path>
          <path d="M6.2 7 5.6 4H3"></path>
          <circle cx="9" cy="19" r="1.4"></circle>
          <circle cx="17.2" cy="19" r="1.4"></circle>
        </svg>
      </button>
    {% endform %}
  {% endif %}
  {% if product.compare_at_price > product.price %}
    <span class="sale-badge">Deal</span>
  {% endif %}
  <a class="product-card__title" href="{{ product.url }}">{{ product.title }}</a>
  <span class="price-row">
    <span class="price">{{ product.price | money }}</span>
    {% if product.compare_at_price > product.price %}
      <span class="compare-price">{{ product.compare_at_price | money }}</span>
    {% endif %}
  </span>
</article>
