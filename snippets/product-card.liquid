{% assign product_image = product.featured_media.preview_image | default: product.featured_image %}
<a class="product-card" href="{{ product.url }}">
  <span class="product-card__media">
    {% if product_image %}
      {{ product_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
  </span>
  {% if product.compare_at_price > product.price %}
    <span class="sale-badge">Deal</span>
  {% endif %}
  <span class="product-card__title">{{ product.title }}</span>
  <span class="price-row">
    <span class="price">{{ product.price | money }}</span>
    {% if product.compare_at_price > product.price %}
      <span class="compare-price">{{ product.compare_at_price | money }}</span>
    {% endif %}
  </span>
</a>
