<div class="top-strip">
  <div class="page-width top-strip__inner">
    <span></span>
    <span>{{ section.settings.service_text }}</span>
  </div>
</div>

<header class="site-header">
  <input class="header-search-toggle" type="checkbox" id="HeaderSearchToggle" aria-hidden="true">
  <input class="header-cart-toggle" type="checkbox" id="HeaderCartToggle" aria-hidden="true">

  <div class="page-width header-main">
    <div class="header-spacer" aria-hidden="true"></div>

    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 720 | image_tag: class: 'brand__logo', loading: 'eager', alt: shop.name }}
      {% else %}
        <span class="brand__mark">S</span>
        <span>SnatchingStore</span>
      {% endif %}
    </a>

    <form class="search-form header-search-form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products">
      <button type="submit">Search</button>
      <label class="header-search-close" for="HeaderSearchToggle" aria-label="Close search">x</label>
    </form>

    <nav class="header-actions" aria-label="Customer links">
      <label class="icon-button search-toggle-button" for="HeaderSearchToggle" aria-label="Open search">
        <svg class="search-icon-svg" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
          <circle cx="26" cy="26" r="17"></circle>
          <line x1="39" y1="39" x2="54" y2="54"></line>
        </svg>
      </label>
      <a class="header-action-link" href="{{ routes.account_login_url }}">
        <svg class="header-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M20 21a8 8 0 0 0-16 0"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        <span>Login</span>
      </a>
      <a class="header-action-link" href="{{ routes.account_register_url }}">
        <svg class="header-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M16 21a7 7 0 0 0-14 0"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M19 8v6"></path>
          <path d="M16 11h6"></path>
        </svg>
        <span>Sign up</span>
      </a>
      <a class="header-action-link header-checkout-link" href="/checkout">
        <svg class="header-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="M3 10h18"></path>
          <path d="M7 15h4"></path>
        </svg>
        <span>Checkout</span>
      </a>
      <label class="header-action-link header-cart-button" for="HeaderCartToggle" aria-label="Open cart" data-cart-count>
        <svg class="header-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6 8h12l-1 12H7L6 8Z"></path>
          <path d="M9 8V6a3 3 0 0 1 6 0v2"></path>
        </svg>
        <span data-cart-count-text>Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</span>
      </label>
    </nav>

    <div class="cart-drawer-shell" aria-label="Cart drawer">
      <label class="cart-drawer-overlay" for="HeaderCartToggle" aria-label="Close cart"></label>
      <aside class="cart-drawer">
        <div class="cart-drawer__header">
          <h2>Your cart</h2>
          <label class="cart-drawer__close" for="HeaderCartToggle" aria-label="Close cart">x</label>
        </div>

        <div class="cart-drawer__empty{% unless cart.empty? %} is-hidden{% endunless %}" data-cart-empty>
          <p>Your cart is empty.</p>
          <a class="button" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
        </div>

        <form class="cart-drawer__form{% if cart.empty? %} is-hidden{% endif %}" action="{{ routes.cart_url }}" method="post" data-cart-form>
          <div class="cart-drawer__items" data-cart-items>
            {% for item in cart.items %}
              <div class="cart-drawer__item">
                <a class="cart-drawer__media" href="{{ item.url }}">
                  {% if item.image %}
                    {{ item.image | image_url: width: 180 | image_tag: loading: 'lazy', alt: item.product.title }}
                  {% endif %}
                </a>
                <div class="cart-drawer__item-info">
                  <a href="{{ item.url }}"><strong>{{ item.product.title }}</strong></a>
                  {% unless item.product.has_only_default_variant %}
                    <span>{{ item.variant.title }}</span>
                  {% endunless %}
                  <span>{{ item.final_line_price | money }}</span>
                  <input class="quantity-input" type="number" name="updates[]" min="0" value="{{ item.quantity }}" aria-label="Quantity for {{ item.product.title }}">
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="cart-drawer__footer">
            <div class="cart-drawer__total">
              <span>Total</span>
              <strong data-cart-total>{{ cart.total_price | money }}</strong>
            </div>
            <button class="button button--dark" type="submit" name="update">Update cart</button>
            <button class="button" type="submit" name="checkout">Checkout</button>
            <a class="cart-drawer__view" href="{{ routes.cart_url }}">View full cart</a>
          </div>
        </form>
      </aside>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Store logo"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo text",
      "default": "Mega deals, home finds, gadgets, beauty and more"
    },
    {
      "type": "text",
      "id": "service_text",
      "label": "Service text",
      "default": "Fast support | Secure checkout | New offers weekly"
    }
  ]
}
{% endschema %}
