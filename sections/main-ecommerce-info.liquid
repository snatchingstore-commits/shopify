<section class="page-width template-page ecommerce-info-page">
  <div class="shelf ecommerce-info-page__panel">
    <div class="shelf__heading">
      <h1>{{ section.settings.heading }}</h1>
    </div>
    <div class="rte ecommerce-info-page__content">
      {{ section.settings.content }}
      {% if page.content != blank %}
        {{ page.content }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ecommerce info page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Store information"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Default content",
      "default": "<p>Add your store information here.</p>"
    }
  ]
}
{% endschema %}
