{% assign featured_collection = section.settings.featured_collection | default: collections.all %}
{% assign deal_collection = section.settings.deal_collection | default: collections.all %}

<section class="page-width market-shell">
  <aside class="category-panel" aria-label="Shop categories">
    <h2>Categories</h2>
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <a class="category-link" href="{{ block.settings.link }}">{{ block.settings.label }}</a>
      {% endif %}
    {% else %}
      {% for collection in collections limit: 8 %}
        {% unless collection.handle == 'frontpage' %}
          <a class="category-link" href="{{ collection.url }}">{{ collection.title }}</a>
        {% endunless %}
      {% endfor %}
    {% endfor %}
  </aside>

  <div class="hero-panel hero-banner-frame" aria-label="Featured banner slider">
    <article class="hero-frame__slide hero-frame__slide--1">
      {% if section.settings.main_banner_1 != blank %}
        {{ section.settings.main_banner_1 | image_url: width: 2400 | image_tag: class: 'hero-frame__image', loading: 'lazy', alt: section.settings.main_banner_1_alt }}
      {% else %}
        <div class="hero-frame__fallback"></div>
      {% endif %}
      <a class="hero-frame__link" href="{{ section.settings.main_banner_1_link | default: section.settings.hero_link }}" aria-label="{{ section.settings.main_banner_1_alt | default: 'Featured promotion' }}"></a>
    </article>
    <article class="hero-frame__slide hero-frame__slide--2">
      {% if section.settings.main_banner_2 != blank %}
        {{ section.settings.main_banner_2 | image_url: width: 2400 | image_tag: class: 'hero-frame__image', loading: 'lazy', alt: section.settings.main_banner_2_alt }}
      {% else %}
        <div class="hero-frame__fallback"></div>
      {% endif %}
      <a class="hero-frame__link" href="{{ section.settings.main_banner_2_link | default: section.settings.hero_link }}" aria-label="{{ section.settings.main_banner_2_alt | default: 'Featured promotion' }}"></a>
    </article>
    <article class="hero-frame__slide hero-frame__slide--3">
      {% if section.settings.main_banner_3 != blank %}
        {{ section.settings.main_banner_3 | image_url: width: 2400 | image_tag: class: 'hero-frame__image', loading: 'lazy', alt: section.settings.main_banner_3_alt }}
      {% else %}
        <div class="hero-frame__fallback"></div>
      {% endif %}
      <a class="hero-frame__link" href="{{ section.settings.main_banner_3_link | default: section.settings.hero_link }}" aria-label="{{ section.settings.main_banner_3_alt | default: 'Featured promotion' }}"></a>
    </article>
    <div class="hero-frame__dots" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</section>

<section class="page-width flash-sale-feature" aria-label="Flash sale promotions">
  <div class="flash-sale-feature__intro">
    <p class="eyebrow">Limited time</p>
    <h2>Flash Sale</h2>
    <p>Fresh offers, quick deals, and short-run finds. Add your strongest sale posters here.</p>
    <a class="button" href="{{ routes.all_products_collection_url }}">Shop offers</a>
  </div>
  <div class="flash-sale-feature__posters">
    <article class="flash-poster flash-poster--1">
      {% if section.settings.flash_poster_1 != blank %}
        {{ section.settings.flash_poster_1 | image_url: width: 2000 | image_tag: class: 'flash-poster__image', loading: 'lazy', alt: section.settings.flash_poster_1_alt }}
      {% endif %}
      <a class="hero-frame__link" href="{{ section.settings.flash_poster_1_link | default: routes.all_products_collection_url }}" aria-label="{{ section.settings.flash_poster_1_alt | default: 'Flash sale poster' }}"></a>
    </article>
    <article class="flash-poster flash-poster--2">
      {% if section.settings.flash_poster_2 != blank %}
        {{ section.settings.flash_poster_2 | image_url: width: 2000 | image_tag: class: 'flash-poster__image', loading: 'lazy', alt: section.settings.flash_poster_2_alt }}
      {% endif %}
      <a class="hero-frame__link" href="{{ section.settings.flash_poster_2_link | default: routes.all_products_collection_url }}" aria-label="{{ section.settings.flash_poster_2_alt | default: 'Flash sale poster' }}"></a>
    </article>
    <article class="flash-poster flash-poster--3">
      {% if section.settings.flash_poster_3 != blank %}
        {{ section.settings.flash_poster_3 | image_url: width: 2000 | image_tag: class: 'flash-poster__image', loading: 'lazy', alt: section.settings.flash_poster_3_alt }}
      {% endif %}
      <a class="hero-frame__link" href="{{ section.settings.flash_poster_3_link | default: routes.all_products_collection_url }}" aria-label="{{ section.settings.flash_poster_3_alt | default: 'Flash sale poster' }}"></a>
    </article>
    <div class="flash-sale-feature__dots" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</section>

<section class="page-width shelf">
  <div class="shelf__heading">
    <h2>{{ section.settings.featured_title }}</h2>
    <a href="{{ featured_collection.url | default: routes.all_products_collection_url }}">See all</a>
  </div>
  <div class="product-grid">
    {% for product in featured_collection.products limit: 10 %}
      {% render 'product-card', product: product %}
    {% else %}
      {% for product in collections.all.products limit: 10 %}
        {% render 'product-card', product: product %}
      {% endfor %}
    {% endfor %}
  </div>
</section>

<section class="page-width shelf">
  <div class="shelf__heading">
    <h2>{{ section.settings.deal_title }}</h2>
    <a href="{{ deal_collection.url | default: routes.all_products_collection_url }}">See all</a>
  </div>
  <div class="product-grid">
    {% for product in deal_collection.products limit: 10 %}
      {% render 'product-card', product: product %}
    {% else %}
      {% for product in collections.all.products limit: 10 %}
        {% render 'product-card', product: product %}
      {% endfor %}
    {% endfor %}
  </div>
</section>

<section class="page-width shelf">
  <div class="shelf__heading">
    <h2>Shop by department</h2>
    <a href="{{ routes.all_products_collection_url }}">Catalog</a>
  </div>
  <div class="collection-grid">
    {% for collection in collections limit: 12 %}
      {% unless collection.handle == 'frontpage' %}
        <a class="collection-tile" href="{{ collection.url }}">{{ collection.title }}</a>
      {% endunless %}
    {% else %}
      <a class="collection-tile" href="{{ routes.all_products_collection_url }}">Home Decor</a>
      <a class="collection-tile" href="{{ routes.all_products_collection_url }}">Beauty</a>
      <a class="collection-tile" href="{{ routes.all_products_collection_url }}">Gadgets</a>
      <a class="collection-tile" href="{{ routes.all_products_collection_url }}">Kitchen</a>
      <a class="collection-tile" href="{{ routes.all_products_collection_url }}">Fashion</a>
      <a class="collection-tile" href="{{ routes.all_products_collection_url }}">Lifestyle</a>
    {% endfor %}
  </div>
</section>

<section class="page-width shelf">
  <div class="shelf__heading">
    <h2>All Products</h2>
    <a href="{{ routes.all_products_collection_url }}">See all</a>
  </div>
  <div class="product-grid">
    {% for product in collections.all.products limit: 20 %}
      {% render 'product-card', product: product %}
    {% endfor %}
  </div>
</section>

<section class="page-width newsletter">
  <div>
    <h2>Get the newest steals first</h2>
    <p>Sign up for product drops, seasonal picks and store updates.</p>
  </div>
  {% form 'customer' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <input type="email" name="contact[email]" placeholder="Email address" required>
    <button class="button" type="submit">Join</button>
  {% endform %}
</section>

{% schema %}
{
  "name": "Marketplace homepage",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Multi-niche deals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Snatch the finds everyone wants"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse useful home decor, lifestyle products and new daily offers in one clean marketplace."
    },
    {
      "type": "url",
      "id": "hero_link",
      "label": "Hero link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Main banner slider 1920 x 600px"
    },
    {
      "type": "image_picker",
      "id": "main_banner_1",
      "label": "Main banner image 1 - 1920 x 600px"
    },
    {
      "type": "text",
      "id": "main_banner_1_alt",
      "label": "Main banner image 1 alt text",
      "default": "SnatchingStore main banner 1"
    },
    {
      "type": "url",
      "id": "main_banner_1_link",
      "label": "Main banner image 1 link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "main_banner_2",
      "label": "Main banner image 2 - 1920 x 600px"
    },
    {
      "type": "text",
      "id": "main_banner_2_alt",
      "label": "Main banner image 2 alt text",
      "default": "SnatchingStore main banner 2"
    },
    {
      "type": "url",
      "id": "main_banner_2_link",
      "label": "Main banner image 2 link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "main_banner_3",
      "label": "Main banner image 3 - 1920 x 600px"
    },
    {
      "type": "text",
      "id": "main_banner_3_alt",
      "label": "Main banner image 3 alt text",
      "default": "SnatchingStore main banner 3"
    },
    {
      "type": "url",
      "id": "main_banner_3_link",
      "label": "Main banner image 3 link",
      "default": "/collections/all"
    },
    {
      "type": "header",
