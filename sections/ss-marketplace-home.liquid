    },
    {
      "type": "image_picker",
      "id": "flash_poster_1",
      "label": "Flash sale poster 1 - 1200 x 700px"
    },
    {
      "type": "text",
      "id": "flash_poster_1_alt",
      "label": "Flash sale poster 1 alt text",
      "default": "SnatchingStore flash sale poster 1"
    },
    {
      "type": "url",
      "id": "flash_poster_1_link",
      "label": "Flash sale poster 1 link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "flash_poster_2",
      "label": "Flash sale poster 2 - 1200 x 700px"
    },
    {
      "type": "text",
      "id": "flash_poster_2_alt",
      "label": "Flash sale poster 2 alt text",
      "default": "SnatchingStore flash sale poster 2"
    },
    {
      "type": "url",
      "id": "flash_poster_2_link",
      "label": "Flash sale poster 2 link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "flash_poster_3",
      "label": "Flash sale poster 3 - 1200 x 700px"
    },
    {
      "type": "text",
      "id": "flash_poster_3_alt",
