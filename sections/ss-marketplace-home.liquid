    },
    {
      "type": "text",
      "id": "deal_title",
      "label": "Deal shelf title",
      "default": "Flash deals"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Home Decor"
        },
        {
          "type": "url",
          "id": "link",
