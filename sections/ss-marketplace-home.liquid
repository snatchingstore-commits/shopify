        { "type": "category", "settings": { "label": "Kitchen & Dining", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Beauty & Care", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Phones & Gadgets", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Fashion", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Lifestyle", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Seasonal Deals", "link": "/collections/all" } },
        { "type": "slide", "settings": { "kicker": "SnatchingStore picks", "heading": "Home decor deals that feel premium", "text": "Feature planters, vases, wall pieces and decorative finds with a strong sale message.", "button_label": "Shop decor", "link": "/collections/all" } },
