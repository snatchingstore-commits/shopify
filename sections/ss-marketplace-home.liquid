        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "default": "/collections/all"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marketplace homepage",
      "blocks": [
        { "type": "category", "settings": { "label": "Artificial Plants", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Wall Planters", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Hanging Decor", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Glass Jar Planters", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "Mini Bottle Decor", "link": "/collections/all" } },
        { "type": "category", "settings": { "label": "All Products", "link": "/collections/all" } },
        { "type": "slide", "settings": { "kicker": "SnatchingStore picks", "heading": "Home decor deals that feel premium", "text": "Feature planters, vases, wall pieces and decorative finds with a strong sale message.", "button_label": "Shop decor", "link": "/collections/all" } },
        { "type": "slide", "settings": { "kicker": "New niches coming", "heading": "Gadgets, beauty and lifestyle in one store", "text": "Use this banner to announce new product categories as you expand.", "button_label": "Explore", "link": "/collections/all" } },
        { "type": "slide", "settings": { "kicker": "Flash shelf", "heading": "Deals made for quick discovery", "text": "Highlight best sellers and fast-moving discounts with a marketplace feel.", "button_label": "View offers", "link": "/collections/all" } }
