<footer class="footer">
  <div class="page-width footer-panel">
    <div>
      <h2>SnatchingStore</h2>
      <p>{{ section.settings.footer_text }}</p>
    </div>
    <div>
      <h3>Shop</h3>
      <div class="footer-links">
        <a href="{{ routes.all_products_collection_url }}">All products</a>
        <a href="{{ routes.search_url }}">Search</a>
        <a href="{{ routes.cart_url }}">Cart</a>
      </div>
    </div>
    <div>
      <h3>Help</h3>
      <div class="footer-links">
        <a href="/pages/contact">Contact</a>
        <a href="/policies/shipping-policy">Shipping policy</a>
        <a href="/policies/refund-policy">Refund policy</a>
        <a href="/policies/privacy-policy">Privacy policy</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer text",
      "default": "A multi-niche store for sharp everyday finds, seasonal deals and useful home upgrades."
    }
  ]
}
{% endschema %}
